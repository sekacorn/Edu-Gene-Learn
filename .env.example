# Database Configuration
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_USER=edugene
POSTGRES_DB=edugenelearn

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-256-bits-change-in-production

# LLM Service Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
XAI_API_KEY=your_xai_api_key_here
LLM_PROVIDER=huggingface  # Options: huggingface, xai

# SSO Configuration (Enterprise)
SSO_ENABLED=false
SSO_PROVIDER=  # Options: okta, auth0, azure-ad, google
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_ISSUER_URL=
SSO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/

# MFA Configuration
MFA_ENABLED=false
MFA_ISSUER=EduGeneLearn

# Monitoring
GRAFANA_PASSWORD=admin

# Application Configuration
ENVIRONMENT=development  # Options: development, staging, production
LOG_LEVEL=INFO

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# File Upload Limits
MAX_FILE_SIZE_MB=100

# AI Model Configuration
AI_MODEL_BATCH_SIZE=32
AI_MODEL_NUM_WORKERS=4

# Resource Monitoring
ENABLE_RESOURCE_MONITORING=true
CPU_THRESHOLD_PERCENT=80
MEMORY_THRESHOLD_PERCENT=85
